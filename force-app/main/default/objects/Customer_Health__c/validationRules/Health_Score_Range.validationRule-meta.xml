<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Health_Score_Range</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
Health_Score__c &lt; 0,
Health_Score__c &gt; 100
)</errorConditionFormula>
    <errorDisplayField>Health_Score__c</errorDisplayField>
    <errorMessage>Health Score must be between 0 and 100.</errorMessage>
</ValidationRule>
